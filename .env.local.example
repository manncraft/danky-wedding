# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# Shared secret embedded in guest QR codes (browser → Vercel)
INTERNAL_SECRET=replace-with-your-invite-secret

# GAS web app URL (from: Deploy → Manage deployments in Apps Script)
# Treat this as a secret — store in Vercel env vars, never in client code.
GAS_ENDPOINT_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Shared secret between Vercel and GAS (must match GUEST_SECRET script property)
# Must be a DIFFERENT value from INTERNAL_SECRET
GAS_SECRET=replace-with-your-gas-secret

# How long (ms) to wait for the GAS response before returning 502 to the guest.
# Increase to 10000 if cold-start timeouts occur in production.
GAS_TIMEOUT_MS=6000
